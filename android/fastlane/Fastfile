default_platform(:android)

platform :android do
  desc "Deploy a new internal testing release to Google Play"
  lane :internal do
    upload_to_play_store(
      track: "internal",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      # NOTE: Must be "draft" while the app is in draft state on Play Console
      # (org still "unreviewed"). Switch to "completed" once the org is approved
      # so deploys auto-publish to internal testers without manual intervention.
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false
    )
  end

  desc "Promote internal testing to production"
  lane :promote_to_production do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end
end
